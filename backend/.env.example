PORT=4000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=nexora_crm

JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=8h

# Comma-separated extra frontend origins (Vercel preview + localhost already allowed)
# CORS_ORIGINS=https://your-custom-domain.com

# WasenderAPI WhatsApp (https://wasenderapi.com/whatsapp/manage/102635)
WASENDER_ENABLED=true
WASENDER_BASE_URL=https://www.wasenderapi.com
WASENDER_SESSION_ID=102635
WASENDER_API_KEY=

# Production deadline WhatsApp cron (every 15m, Asia/Karachi)
CRON_ENABLED=true

# Office check-in geofence (Asia/Karachi team — browser GPS must be inside radius)
# Set enabled=true and paste office coordinates from Google Maps (right-click → coords)
OFFICE_GEOFENCE_ENABLED=false
OFFICE_LAT=
OFFICE_LNG=
OFFICE_RADIUS_METERS=150
# Optional — only if you later want a map picker UI (distance check does not need this)
GOOGLE_MAPS_API_KEY=
